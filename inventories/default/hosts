#::                                   ANSIBLE INVENTORY
#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
#::::::::::::::::::::::::::::// RTD-Ansible default inventory //:::::::::::::::::::::::// Ansible / Linux //:::::::::::::
#:: Purpose:
#::   Define the default inventory groups used by RTD-Ansible playbooks and
#::   wrapper scripts.
#::
#:: How this file works:
#::   - ansible.cfg points inventory to ./inventories/default/hosts.
#::   - [localhost] targets the control machine with a local connection.
#::   - [wks] contains the default workstation address range.
#::   - [all_servers] contains the default managed server address range.
#::   - [workstations] is a readable alias group that includes [wks].
#::   - [servers] is a readable alias group that includes [all_servers].
#::   - [all_hosts] includes both workstation and server groups.
#::
#:: Usage:
#::   Run Ansible from the repository root so ansible.cfg loads this inventory:
#::
#::     ansible-playbook playbooks/server-auto-config.yml
#::     ./scripts/update-all-server-software.sh
#::
#:: Notes:
#::   Inventory groups use standard Ansible INI syntax. Host ranges such as
#::   192.168.1.[2:199] expand to every address in that range. A host may be a
#::   member of more than one group if it is listed in multiple sections or
#::   inherited through a :children group.
#::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::

# Local control host. Used by local-only playbooks and generated site playbooks.
[localhost]
localhost ansible_connection=local

# Default workstation range.
[wks]
192.168.1.[2:199]

# Default managed server range.
# update-all-server-software.sh runs the update playbook for this group.
[all_servers]
192.168.1.[200:254]

# Friendly alias for the workstation group.
[workstations:children]
wks

# Friendly alias for the managed server group.
[servers:children]
all_servers

# Friendly alias for all hosts.
[all_hosts:children]
wks
all_servers
